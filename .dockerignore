# ==========================
# SYSTEM & IDE
# ==========================
.ignore/
.git
.gitignore
.vscode
.idea
.DS_Store

# ==========================
# PYTHON (Crucial for Speed)
# ==========================
# Ignore local virtual environments (Fixes the slow build context loading)
.venv
venv
env

# Bytecode and caches
__pycache__
*.pyc
*.pyo
*.pyd
.pytest_cache
*.egg-info
.coverage

# ==========================
# DATA FILES
# ==========================
# Ignore raw Excel uploads (Users should upload these via app)
*.csv
!.config/
!.config/table_structure.csv
*.xlsb
*.xlsx
*.parquet
*.zip
*.tmp
*.part
desa_db/dbs/
desa_db/staging/

# EXCEPTION: Keep config CSVs
!.config/
!.config/table_structure.csv


# ==========================
# FRONTEND (Next.js / Node)
# ==========================
# Ignore dependencies (Docker installs them fresh)
node_modules
.npm
.yarn
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Build outputs
.next
out
coverage
.vercel
*.tsbuildinfo
